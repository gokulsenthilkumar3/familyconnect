// FamilyConnect — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  profilePic   String?
  preferences  Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedTrees    FamilyTree[]   @relation("TreeOwner")
  accessControl AccessControl[]
  createdMembers Member[]      @relation("MemberCreator")
  notifications Notification[]

  @@map("users")
}

// ─── Family Trees ─────────────────────────────────────────────────────────────

model FamilyTree {
  id           String   @id @default(cuid())
  name         String
  ownerId      String
  rootMemberId String?
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner         User           @relation("TreeOwner", fields: [ownerId], references: [id])
  members       Member[]
  relationships Relationship[]
  events        Event[]
  documents     Document[]
  accessControl AccessControl[]

  @@index([ownerId])
  @@map("family_trees")
}

// ─── Members ──────────────────────────────────────────────────────────────────

model Member {
  id            String    @id @default(cuid())
  treeId        String
  name          String
  birthDate     DateTime?
  birthLocation String?
  deathDate     DateTime?
  gender        Gender?
  religion      String?
  bio           String?
  occupation    String?
  photoUrl      String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tree          FamilyTree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("MemberCreator", fields: [createdById], references: [id])
  relationships1 Relationship[] @relation("Member1")
  relationships2 Relationship[] @relation("Member2")
  events        Event[]
  documents     Document[]

  @@index([treeId])
  @@index([treeId, name])
  @@map("members")
}

enum Gender {
  male
  female
  other
}

// ─── Relationships ────────────────────────────────────────────────────────────

model Relationship {
  id               String           @id @default(cuid())
  treeId           String
  member1Id        String
  member2Id        String
  type             RelationshipType
  customLabel      String?
  marriageDate     DateTime?
  divorceDate      DateTime?
  createdAt        DateTime         @default(now())

  tree    FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  member1 Member     @relation("Member1", fields: [member1Id], references: [id])
  member2 Member     @relation("Member2", fields: [member2Id], references: [id])

  @@index([treeId, member1Id])
  @@index([treeId, member2Id])  // covers reverse-direction relationship lookups
  @@map("relationships")
}

enum RelationshipType {
  parent
  child
  spouse
  sibling
  cousin
  aunt_uncle
  niece_nephew
  inlaw
  friend
  godparent
  mentor
  step_parent
  step_child
  adopted
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  treeId      String
  memberId    String?
  type        EventType
  title       String
  date        DateTime
  location    String?
  description String?
  photos      String[]
  createdAt   DateTime  @default(now())

  tree   FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  member Member?    @relation(fields: [memberId], references: [id])

  @@index([treeId, date])
  @@map("events")
}

enum EventType {
  birthday
  marriage
  death
  anniversary
  festival
  gathering
  migration
  achievement
}

// ─── Documents ────────────────────────────────────────────────────────────────

model Document {
  id         String       @id @default(cuid())
  treeId     String
  memberId   String?
  type       DocumentType
  fileUrl    String
  fileName   String
  uploadedAt DateTime     @default(now())

  tree   FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  member Member?    @relation(fields: [memberId], references: [id])

  @@index([treeId, memberId])  // member profile document gallery queries
  @@map("documents")
}

enum DocumentType {
  birth_certificate
  marriage_certificate
  passport
  property_deed
  photo
  other
}

// ─── Access Control ───────────────────────────────────────────────────────────

model AccessControl {
  id        String   @id @default(cuid())
  treeId    String
  userId    String
  role      Role     @default(viewer)
  grantedAt DateTime @default(now())

  tree FamilyTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id])

  @@unique([treeId, userId])
  @@index([treeId, userId])
  @@map("access_control")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])  // fast unread-count queries per user
  @@map("notifications")
}

enum Role {
  viewer
  editor
  admin
  family_head
}
